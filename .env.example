# Meta WhatsApp API Configuration
META_VERIFY_TOKEN=your_meta_verify_token_here
META_WHATSAPP_TOKEN=your_meta_whatsapp_access_token_here
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
META_APP_SECRET=your_meta_app_secret_here

# Supabase Configuration
SUPABASE_URL=https://your_supabase_project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# AI Configuration (gemini | anthropic | openai)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Optional keys (only required if AI_PROVIDER is set to corresponding provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# App Environment Configuration (development | production)
APP_ENV=production
LOG_LEVEL=INFO
PORT=8000
